{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "pollora-starter/hero",
    "version": "1.0.0",
    "title": "Hero",
    "category": "widgets",
    "icon": "cover-image",
    "description": "A visually striking hero section with heading, description and call-to-action.",
    "keywords": ["hero", "banner", "header"],
    "textdomain": "pollora-starter",
    "attributes": {
        "heading": {
            "type": "string",
            "default": ""
        },
        "description": {
            "type": "string",
            "default": ""
        },
        "buttonText": {
            "type": "string",
            "default": ""
        },
        "buttonUrl": {
            "type": "string",
            "default": "#"
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"]
    },
    "editorScript": "file:./index.jsx",
    "editorStyle": "file:./editor.css",
    "style": "file:./style.css",
    "viewScript": "file:./view.js"
}
